# Server
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=finance
DB_SSLMODE=disable

# Or provide a full connection string instead:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/finance?sslmode=disable

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY_MINUTES=15

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*
